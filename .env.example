# Copy this file to .env and fill in the values for your tenant.
# Never commit your real .env file — it contains credentials.

# ─── Azure AD authentication (required) ─────────────────────────────────────
# Register a dedicated App Registration for this watcher in Microsoft Entra ID,
# then grant it the APPLICATION permission "Application.Read.All" (Microsoft
# Graph) and click "Grant admin consent". This tool only ever issues GET
# requests — it cannot read secret values (Graph never returns them after
# creation) and cannot modify anything.
#
# If you also enable NOTIFY_OWNERS below, additionally grant "User.Read.All"
# so owner user principal names/emails can be resolved.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Option A: client secret auth (simplest to set up).
# NOTE: this means the watcher itself depends on a secret that will someday
# expire — set a calendar reminder, or prefer Option B below.
AZURE_CLIENT_SECRET=

# Option B: client certificate auth (recommended for long-lived deployments).
# Mount your .pem (private key + certificate chain) into the container, e.g.
# via the ./certs volume in docker-compose.yml, and point to it here instead
# of setting AZURE_CLIENT_SECRET.
# AZURE_CLIENT_CERTIFICATE_PATH=/certs/watcher.pem
# AZURE_CLIENT_CERTIFICATE_PASSWORD=

# ─── Scan behavior ───────────────────────────────────────────────────────────
# Comma-separated list of "days before expiry" thresholds. An alert is sent
# once a credential first crosses into each threshold (e.g. a secret expiring
# in 20 days will alert on the "14" threshold, then again on "7").
WARNING_THRESHOLDS_DAYS=30,14,7,1

# Which credential types to scan.
INCLUDE_SECRETS=true
INCLUDE_CERTIFICATES=true

# Also scan Enterprise Applications (service principals) for expiring SAML
# SSO signing certificates — a completely separate object from App
# Registrations, easy to miss otherwise (many SAML SSO apps have no App
# Registration at all, only a service principal). Uses the same
# Application.Read.All permission (it covers reading service principals
# too), but does mean enumerating every service principal in the tenant,
# including built-in Microsoft ones, so it adds some Graph API traffic.
INCLUDE_ENTERPRISE_APPS=true

# How often (in days) to re-send a reminder for credentials that are already
# expired and still haven't been rotated/removed.
EXPIRED_REMINDER_INTERVAL_DAYS=7

# Look up each affected application's owners and include their email/UPN in
# notifications. Requires the "User.Read.All" Graph permission in addition to
# "Application.Read.All".
NOTIFY_OWNERS=false

# ─── Scheduling ──────────────────────────────────────────────────────────────
# "loop" (default): the container runs continuously and scans on the cron
#   schedule below (5-field cron syntax, evaluated in UTC).
# "once": scan a single time and exit — use this if you're driving the
#   schedule yourself via host cron, systemd, or a Kubernetes CronJob (see
#   docker-compose.once.yml for an example).
RUN_MODE=loop
CRON_SCHEDULE=0 8 * * *
# Run one scan immediately on startup, in addition to the cron schedule above,
# so the web dashboard has data right away instead of waiting for the first
# scheduled run. Only applies in RUN_MODE=loop.
RUN_SCAN_ON_STARTUP=true

# ─── Web dashboard ───────────────────────────────────────────────────────────
# A small read-only dashboard listing every scanned credential and its
# expiry status, plus a "scan now" button. Only shown in RUN_MODE=loop.
WEB_UI_ENABLED=true
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8080
# Strongly recommended: set both to enable HTTP Basic Auth on the dashboard.
# Left blank, the dashboard has NO authentication — only safe if the port
# is not reachable from outside your own network (see docker-compose.yml).
WEB_UI_USERNAME=
WEB_UI_PASSWORD=

# ─── State & status ──────────────────────────────────────────────────────────
# SQLite file used to avoid re-sending the same alert on every run. Mount a
# volume over its parent directory so state survives restarts.
STATE_DB_PATH=/data/state.db
# JSON file with the outcome of the most recent run; also used by the Docker
# HEALTHCHECK.
STATUS_FILE_PATH=/data/last_run.json
# JSON file with the full credential inventory shown on the web dashboard.
INVENTORY_FILE_PATH=/data/inventory.json
# Rolling log of past scan runs, shown in the dashboard's "scan history" panel.
# Entries older than 24 hours are dropped automatically; this is just a safety
# cap on how many runs can pile up within that window (e.g. frequent manual scans).
SCAN_HISTORY_FILE_PATH=/data/scan_history.json
SCAN_HISTORY_LIMIT=20
# JSON file storing any notification/threshold overrides made from the web
# dashboard's Monitoring page. Applied on top of the settings below at startup.
SETTINGS_FILE_PATH=/data/settings.json

# If true, alerts are logged but never actually sent and dedupe state is not
# updated. Useful for a first run to see what would be reported.
DRY_RUN=false

LOG_LEVEL=INFO

# ─── Notification channels (enable one or more) ─────────────────────────────

# -- Email (SMTP) --
NOTIFY_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=azure-secret-watch@example.com
# Comma-separated list of recipients.
EMAIL_TO=security-team@example.com

# -- Microsoft Teams --
# In Teams, open the "Workflows" app from the left-hand app rail (not a
# "Power Automate" tab added to a channel), use the "Send webhook alerts to
# a chat" template, pick the destination chat/channel, and paste the
# generated URL here.
NOTIFY_TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=
# "adaptive_card" (default, works with Teams Workflows) or "messagecard"
# (legacy Office 365 Connector webhooks — deprecated by Microsoft but still
# supported by some existing setups).
TEAMS_WEBHOOK_FORMAT=adaptive_card

# -- Custom webhook --
# Sends a generic JSON payload ({"summary": {...}, "alerts": [...]}) — wire
# this up to Slack (via a relay), PagerDuty, ntfy, your own service, etc.
NOTIFY_WEBHOOK_ENABLED=false
CUSTOM_WEBHOOK_URL=
CUSTOM_WEBHOOK_METHOD=POST
# Optional JSON object of extra headers, e.g. for bearer-token auth:
# CUSTOM_WEBHOOK_HEADERS={"Authorization": "Bearer <token>"}
CUSTOM_WEBHOOK_HEADERS=

# ─── Advanced ────────────────────────────────────────────────────────────────
GRAPH_PAGE_SIZE=999
REQUEST_TIMEOUT_SECONDS=30
